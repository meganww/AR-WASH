    '<span id="p-net-' + i + '">0</span>' +
    '<span id="p-hand-' + i + '">-</span>' +
    '<span id="p-stat-' + i + '">-</span>';
  palletBody.appendChild(row);
});
palletBody.addEventListener('input', calcHandoff);

// Build buffer rows
var bufferBody = document.getElementById('bufferBody');
BUFFERS.forEach(function(b, i) {
  var row = document.createElement('div');
  row.className = 'staffing-row';
  row.style.cssText = 'grid-template-columns:1.2fr repeat(4,1fr) 1fr 1fr 0.8fr;';
  row.innerHTML =
    '<span style="font-weight:700;color:#7c3aed;">' + b.name + '</span>' +
    '<span><input type="number" step="0.1" class="handoff-input" id="b-sos-' + i + '" value="0"></span>' +
    '<span><input type="number" step="0.1" class="handoff-input" id="b-eos-' + i + '" value="0"></span>' +
    '<span style="color:#9ca3af;">' + b.min + '</span>' +
    '<span style="color:#9ca3af;">' + (b.max === Infinity ? '∞' : b.max) + '</span>' +
    '<span id="b-sstat-' + i + '">-</span>' +
    '<span id="b-estat-' + i + '">-</span>' +
    '<span id="b-chg-' + i + '">0</span>';
  bufferBody.appendChild(row);
});
bufferBody.addEventListener('input', calcHandoff);

// AA Productivity
var aaBody = document.getElementById('aaBody');
var aaCount = 0;
function addAA() {
  var id = aaCount++;
  var row = document.createElement('div');
  row.className = 'staffing-row'; row.id = 'aa-' + id;
  row.style.cssText = 'grid-template-columns:1.2fr 1fr 0.8fr 0.8fr 0.8fr 0.8fr 0.8fr;';
  var opts = Object.keys(AA_OPS).map(function(o) { return '<option>' + o + '</option>'; }).join('');
  row.innerHTML =
    '<span><input type="text" class="handoff-input handoff-text-input" id="aa-name-' + id + '" placeholder="Name"></span>' +
    '<span><select class="handoff-select" id="aa-op-' + id + '">' + opts + '</select></span>' +
    '<span><input type="number" class="handoff-input" id="aa-hrs-' + id + '" value="10" step="0.5"></span>' +
    '<span><input type="number" class="handoff-input" id="aa-units-' + id + '" value="0"></span>' +
    '<span id="aa-uph-' + id + '">0</span>' +
    '<span id="aa-tgt-' + id + '">' + Object.values(AA_OPS)[0] + '</span>' +
    '<span id="aa-gap-' + id + '">-</span>';
  aaBody.appendChild(row);
  document.getElementById('aa-op-' + id).addEventListener('change', calcHandoff);
}
addAA(); addAA();
aaBody.addEventListener('input', calcHandoff);

function R(n) { return Math.round(n * 100) / 100; }

function calcHandoff() {
  var issues = 0, warnings = 0;

  PALLETS.forEach(function(p, i) {
    var sos = val('p-sos-' + i), build = val('p-build-' + i), proc = val('p-proc-' + i);
    var eos = sos + build - proc, net = eos - sos, expectedMax = sos + p.buildRate;
    document.getElementById('p-eos-' + i).textContent = R(eos);
    document.getElementById('p-net-' + i).textContent = R(net);
    var hEl = document.getElementById('p-hand-' + i), sEl = document.getElementById('p-stat-' + i);
    if (eos < 0) { hEl.textContent = '✗ Negative EOS'; hEl.className = 'ho-fail'; sEl.textContent = 'Data Error'; sEl.className = 'ho-fail'; issues++; }
    else if (eos === 0) { hEl.textContent = '✓ Clean Handoff'; hEl.className = 'ho-pass'; sEl.textContent = 'Clean Handoff'; sEl.className = 'ho-pass'; }
    else if (eos <= sos) { hEl.textContent = '✓ Controlled'; hEl.className = 'ho-pass'; sEl.textContent = 'WIP Controlled'; sEl.className = 'ho-pass'; }
    else if (eos <= expectedMax) { hEl.textContent = '⚠ Expected Growth'; hEl.className = 'ho-warn'; sEl.textContent = 'Monitor'; sEl.className = 'ho-warn'; warnings++; }
    else { hEl.textContent = '✗ Over Expected'; hEl.className = 'ho-fail'; sEl.textContent = 'Action Needed'; sEl.className = 'ho-fail'; issues++; }
  });

  BUFFERS.forEach(function(b, i) {
    var sos = val('b-sos-' + i), eos = val('b-eos-' + i);
    document.getElementById('b-chg-' + i).textContent = R(eos - sos);
    [['sstat', sos], ['estat', eos]].forEach(function(pair) {
      var el = document.getElementById('b-' + pair[0] + '-' + i), v = pair[1];
      if (v < b.min) { el.textContent = '✗ Below Min'; el.className = 'ho-fail'; issues++; }
      else if (v > b.max) { el.textContent = '✗ Over Max'; el.className = 'ho-fail'; issues++; }
      else if (b.max !== Infinity && v >= b.max * 0.85) { el.textContent = '⚠ Near Max'; el.className = 'ho-warn'; warnings++; }
      else { el.textContent = '✓ OK'; el.className = 'ho-pass'; }
    });
  });

  aaBody.querySelectorAll('[id^="aa-"]').forEach(function(row) {
    if (!row.id.match(/^aa-\d+$/)) return;
    var id = row.id.split('-')[1];
    var op = document.getElementById('aa-op-' + id).value;
    var hrs = val('aa-hrs-' + id) || 10, units = val('aa-units-' + id);
    var uph = hrs > 0 ? Math.round((units / hrs) * 10) / 10 : 0;
    var target = AA_OPS[op] || 10, gap = Math.round((uph - target) * 10) / 10;
    document.getElementById('aa-uph-' + id).textContent = uph;
    document.getElementById('aa-tgt-' + id).textContent = target;
    var el = document.getElementById('aa-gap-' + id);
    if (gap >= 0) { el.textContent = '+' + gap; el.className = 'ho-pass'; }
    else { el.textContent = gap.toString(); el.className = 'ho-fail'; }
  });

  var box = document.getElementById('overallBox');
  if (issues > 0) { box.textContent = 'NEEDS ATTENTION (' + issues + ' issues)'; box.className = 'handoff-overall handoff-bad'; }
  else if (warnings > 0) { box.textContent = 'MONITOR (' + warnings + ' warnings)'; box.className = 'handoff-overall handoff-warn'; }
  else { box.textContent = 'ALL CLEAR – Good Handoff'; box.className = 'handoff-overall handoff-ok'; }
}

// ===== HANDOFF SAVE / HISTORY =====
function getHistory() { return JSON.parse(localStorage.getItem('shiftHist') || '{}'); }
function putHistory(h) { localStorage.setItem('shiftHist', JSON.stringify(h)); }

function snapshot() {
  var pallets = PALLETS.map(function(_, i) {
    return { sos: val('p-sos-' + i), build: val('p-build-' + i), proc: val('p-proc-' + i),
      eos: parseFloat(document.getElementById('p-eos-' + i).textContent) || 0,
      net: parseFloat(document.getElementById('p-net-' + i).textContent) || 0,
      hand: document.getElementById('p-hand-' + i).textContent,
      stat: document.getElementById('p-stat-' + i).textContent };
  });
  var buffers = BUFFERS.map(function(_, i) {
    return { sos: val('b-sos-' + i), eos: val('b-eos-' + i),
      chg: parseFloat(document.getElementById('b-chg-' + i).textContent) || 0,
      sstat: document.getElementById('b-sstat-' + i).textContent,
      estat: document.getElementById('b-estat-' + i).textContent };
  });
  var aas = [];
  aaBody.querySelectorAll('[id^="aa-"]').forEach(function(row) {
    if (!row.id.match(/^aa-\d+$/)) return;
    var id = row.id.split('-')[1];
    aas.push({ name: document.getElementById('aa-name-' + id).value,
      op: document.getElementById('aa-op-' + id).value,
      hrs: val('aa-hrs-' + id), units: val('aa-units-' + id),
      uph: document.getElementById('aa-uph-' + id).textContent,
      gap: document.getElementById('aa-gap-' + id).textContent });
  });
  return { date: document.getElementById('trackDate').value, shift: document.getElementById('shiftSelect').value,
    pallets: pallets, buffers: buffers, aas: aas,
    overall: document.getElementById('overallBox').textContent, ts: Date.now() };
}

function saveShift() {
  calcHandoff();
  var snap = snapshot(), key = snap.date + '_' + snap.shift;
  var h = getHistory(); h[key] = snap; putHistory(h);
  alert('Saved: ' + snap.date + ' ' + snap.shift);
  renderHistory();
}

function loadSnap(key) {
  var h = getHistory(), d = h[key]; if (!d) return;
  document.getElementById('trackDate').value = d.date;
  document.getElementById('shiftSelect').value = d.shift;
  d.pallets.forEach(function(p, i) {
    document.getElementById('p-sos-' + i).value = p.sos;
    document.getElementById('p-build-' + i).value = p.build;
    document.getElementById('p-proc-' + i).value = p.proc;
  });
  d.buffers.forEach(function(b, i) {
    document.getElementById('b-sos-' + i).value = b.sos;
    document.getElementById('b-eos-' + i).value = b.eos;
  });
  aaBody.innerHTML = ''; aaCount = 0;
  (d.aas || []).forEach(function(aa) {
    addAA(); var id = aaCount - 1;
    document.getElementById('aa-name-' + id).value = aa.name || '';
    document.getElementById('aa-op-' + id).value = aa.op || 'Shoes';
    document.getElementById('aa-hrs-' + id).value = aa.hrs || 10;
    document.getElementById('aa-units-' + id).value = aa.units || 0;
  });
  if (!d.aas || !d.aas.length) { addAA(); addAA(); }
  calcHandoff();
}

function clearHandoffForm() {
  if (!confirm('Clear form? (History is preserved)')) return;
  document.querySelectorAll('#palletBody input, #bufferBody input').forEach(function(el) { el.value = 0; });
  aaBody.innerHTML = ''; aaCount = 0; addAA(); addAA();
  calcHandoff();
}

function delHist(key) {
  if (!confirm('Delete this entry?')) return;
  var h = getHistory(); delete h[key]; putHistory(h); renderHistory();
}

function renderHistory() {
  var h = getHistory();
  var shiftF = document.getElementById('histShift').value;
  var fromF = document.getElementById('histFrom').value;
  var toF = document.getElementById('histTo').value;
  var entries = Object.entries(h).sort(function(a, b) { return b[1].ts - a[1].ts; });
  if (shiftF) entries = entries.filter(function(e) { return e[1].shift === shiftF; });
  if (fromF) entries = entries.filter(function(e) { return e[1].date >= fromF; });
  if (toF) entries = entries.filter(function(e) { return e[1].date <= toF; });

  var list = document.getElementById('historyList');
  if (!entries.length) { list.innerHTML = '<p style="color:#9ca3af;">No history found.</p>'; return; }

  list.innerHTML = entries.map(function(pair) {
    var key = pair[0], d = pair[1];
    var cls = d.overall.indexOf('CLEAR') >= 0 ? 'ho-pass' : d.overall.indexOf('MONITOR') >= 0 ? 'ho-warn' : 'ho-fail';
    var detail = '<table><thead><tr><th>Operation</th><th>SOS</th><th>Build</th><th>Proc</th><th>EOS</th><th>Net</th><th>Status</th></tr></thead><tbody>';
    d.pallets.forEach(function(p, i) { detail += '<tr><td style="font-weight:700;color:#7c3aed;">' + PALLETS[i].name + '</td><td>' + p.sos + '</td><td>' + p.build + '</td><td>' + p.proc + '</td><td>' + p.eos + '</td><td>' + p.net + '</td><td>' + p.stat + '</td></tr>'; });
    detail += '</tbody></table><table style="margin-top:6px"><thead><tr><th>Buffer</th><th>SOS</th><th>EOS</th><th>Chg</th><th>SOS Status</th><th>EOS Status</th></tr></thead><tbody>';
    d.buffers.forEach(function(b, i) { detail += '<tr><td style="font-weight:700;color:#7c3aed;">' + BUFFERS[i].name + '</td><td>' + b.sos + '</td><td>' + b.eos + '</td><td>' + b.chg + '</td><td>' + b.sstat + '</td><td>' + b.estat + '</td></tr>'; });
    detail += '</tbody></table>';
    if (d.aas && d.aas.length) {
      detail += '<table style="margin-top:6px"><thead><tr><th>AA</th><th>Op</th><th>Hrs</th><th>Units</th><th>UPH</th><th>Gap</th></tr></thead><tbody>';
      d.aas.forEach(function(a) { detail += '<tr><td>' + (a.name || '-') + '</td><td>' + a.op + '</td><td>' + a.hrs + '</td><td>' + a.units + '</td><td>' + a.uph + '</td><td>' + a.gap + '</td></tr>'; });
      detail += '</tbody></table>';
    }
    return '<div class="hist-entry" onclick="this.classList.toggle(\'expanded\')">' +
      '<div class="hist-header"><span class="hist-date">' + d.date + ' – ' + d.shift + '</span><span class="' + cls + '">' + d.overall + '</span>' +
      '<span><button class="save-btn" style="background:#2563eb;font-size:0.7rem;padding:4px 10px;" onclick="event.stopPropagation();loadSnap(\'' + key + '\')">Load</button> ' +
      '<button class="save-btn" style="background:#dc2626;font-size:0.7rem;padding:4px 10px;" onclick="event.stopPropagation();delHist(\'' + key + '\')">✗</button></span></div>' +
      '<div class="hist-detail">' + detail + '</div></div>';
  }).join('');
}

function handoffExportCSV() {
  calcHandoff();
  var s = snapshot();
  var csv = 'Shift Handoff Report\nDate,' + s.date + '\nShift,' + s.shift + '\n\n';
  csv += 'PALLET TRACKING\nOperation,SOS,WIP Build,Processed,EOS,Net Change,Handoff,Status\n';
  s.pallets.forEach(function(p, i) { csv += PALLETS[i].name + ',' + p.sos + ',' + p.build + ',' + p.proc + ',' + p.eos + ',' + p.net + ',' + p.hand + ',' + p.stat + '\n'; });
  csv += '\nBUFFER CHECKS\nArea,SOS,EOS,Change,SOS Status,EOS Status\n';
  s.buffers.forEach(function(b, i) { csv += BUFFERS[i].name + ',' + b.sos + ',' + b.eos + ',' + b.chg + ',' + b.sstat + ',' + b.estat + '\n'; });
  csv += '\nAA PRODUCTIVITY\nName,Operation,Hours,Units,UPH,Gap\n';
  s.aas.forEach(function(a) { csv += (a.name || '-') + ',' + a.op + ',' + a.hrs + ',' + a.units + ',' + a.uph + ',' + a.gap + '\n'; });
  csv += '\nOverall,' + s.overall + '\n';
  var blob = new Blob([csv], {type: 'text/csv'});
  var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = 'shift_' + s.date + '_' + s.shift + '.csv'; a.click();
}

// Initial calculations
calcHandoff();
  </script>
