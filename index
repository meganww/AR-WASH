// ===== TAB SWITCHING =====
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(btn.dataset.tab).classList.add('active');
    if (btn.dataset.tab === 'daily-wash') updateDailyWash();
    if (btn.dataset.tab === 'handoff') renderHistory();
  });
});

// ===== SHIFT PLANNER SAVE/EDIT =====
document.getElementById('save-planner-btn').addEventListener('click', function() {
  document.querySelectorAll('#shift-planner input').forEach(inp => { inp.disabled = true; inp.classList.add('locked'); });
  this.textContent = '✓ Saved'; this.classList.add('saved'); this.disabled = true;
  document.getElementById('edit-planner-btn').style.display = 'inline-block';
});
document.getElementById('edit-planner-btn').addEventListener('click', function() {
  document.querySelectorAll('#shift-planner input').forEach(inp => { inp.disabled = false; inp.classList.remove('locked'); });
  var s = document.getElementById('save-planner-btn');
  s.textContent = 'Save Planner'; s.classList.remove('saved'); s.disabled = false;
  this.style.display = 'none';
