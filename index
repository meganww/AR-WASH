// ===== PLANNER CALCULATION =====
function val(id) { return parseFloat(document.getElementById(id).value) || 0; }
function excess(v, t) { return Math.max(0, v - t); }
function fmt(n) { return Math.round(n).toLocaleString(); }

['crets','ar-pickable','ar-tech-pickable','grading-wip','ps-wip','shoes-wip','tech-wip','refurb-wip','blancco-wip','goal-rate',
 'rate-grading','rate-tech','rate-ps','rate-shoes','rate-refurb','rate-blancco','rate-ns-path','rate-spar-path',
 'ns-wip','ns-rate','spar-wip','spar-rate'].forEach(id => {
  document.getElementById(id).addEventListener('input', calculate);
});

function calculate() {
  var crets = val('crets'), arPickable = val('ar-pickable'), arTech = val('ar-tech-pickable');
  var rCrets = crets * 0.035;
  var rArPickable = excess(arPickable, 500), rArTech = excess(arTech, 500);
  var rGrading = excess(val('grading-wip'), 3) * 100;
  var rPs = excess(val('ps-wip'), 0.5) * 100;
  var rShoes = excess(val('shoes-wip'), 1) * 100;
  var rTech = excess(val('tech-wip'), 2) * 485;
  var rRefurb = excess(val('refurb-wip'), 1) * 100;
  var rBlancco = excess(val('blancco-wip'), 1) * 100;
  var total = rCrets + rArPickable + rArTech + rGrading + rPs + rShoes + rTech + rRefurb + rBlancco;

  document.getElementById('result-crets').textContent = fmt(rCrets);
  document.getElementById('result-ar-pickable').textContent = fmt(rArPickable);
  document.getElementById('result-ar-tech-pickable').textContent = fmt(rArTech);
  document.getElementById('result-grading').textContent = fmt(rGrading);
  document.getElementById('result-ps').textContent = fmt(rPs);
  document.getElementById('result-shoes').textContent = fmt(rShoes);
  document.getElementById('result-tech').textContent = fmt(rTech);
  document.getElementById('result-refurb').textContent = fmt(rRefurb);
  document.getElementById('result-blancco').textContent = fmt(rBlancco);
  document.getElementById('total').textContent = fmt(total);

  // Path staffing
  var pathDepts = [
    {key:'grading',pct:0.03159,wipUnits:rGrading},{key:'tech',pct:0.00646,wipUnits:rTech},
    {key:'ps',pct:0.00048,wipUnits:rPs},{key:'shoes',pct:0.0018,wipUnits:rShoes},
    {key:'refurb',pct:0.00273,wipUnits:rRefurb},{key:'blancco',pct:0.00067,wipUnits:rBlancco}
  ];
  var pathTotalHC = 0;
  pathDepts.forEach(function(d) {
    var cv = crets * d.pct, dv = cv + d.wipUnits;
    var rate = parseFloat(document.getElementById('rate-' + d.key).value) || 1;
    var hc = Math.ceil(dv / rate / 10); pathTotalHC += hc;
    document.getElementById('path-crets-' + d.key).textContent = fmt(cv);
    document.getElementById('path-wip-' + d.key).textContent = fmt(d.wipUnits);
    document.getElementById('path-vol-' + d.key).textContent = fmt(dv);
    document.getElementById('path-hc-' + d.key).textContent = hc;
  });
  document.getElementById('path-hc-total').textContent = pathTotalHC;

  // NS path row
  var nsCV = crets * 0.037, nsWV = excess(val('ns-wip'), 4) * 100, nsT = nsCV + nsWV;
  var nsR = parseFloat(document.getElementById('rate-ns-path').value) || 175;
  document.getElementById('path-crets-ns').textContent = fmt(nsCV);
  document.getElementById('path-wip-ns').textContent = fmt(nsWV);
  document.getElementById('path-vol-ns').textContent = fmt(nsT);
  document.getElementById('path-hc-ns').textContent = nsT > 0 ? Math.ceil(nsT / nsR / 10) : 0;

  // SPAR path row
  var spCV = crets * 0.002, spWV = excess(val('spar-wip'), 2) * 375, spT = spCV + spWV;
  var spR = parseFloat(document.getElementById('rate-spar-path').value) || 2;
  document.getElementById('path-crets-spar').textContent = fmt(spCV);
  document.getElementById('path-wip-spar').textContent = fmt(spWV);
  document.getElementById('path-vol-spar').textContent = fmt(spT);
  document.getElementById('path-hc-spar').textContent = spT > 0 ? Math.ceil(spT / spR / 10) : 0;

  // Staffing plan
  var goalRate = val('goal-rate');
  if (goalRate > 0 && total > 0) {
    var tsh = total / goalRate;
    var roles = [{key:'lead-pa',pct:0.17},{key:'5s',pct:0.01},{key:'ps',pct:0.12},{key:'qa',pct:0.02},{key:'wd-tl',pct:0.21},{key:'waterspider',pct:0.47}];
    document.getElementById('total-support-hours').textContent = tsh.toFixed(1);
    var totalHC = 0;
    roles.forEach(function(r) {
      var h = tsh * r.pct, hc = Math.ceil(h / 10); totalHC += hc;
      document.getElementById('hours-' + r.key).textContent = h.toFixed(1);
      document.getElementById('hc-' + r.key).textContent = hc;
    });
    document.getElementById('hc-total').textContent = totalHC;
  } else {
    ['total-support-hours','hc-total'].forEach(function(id) { document.getElementById(id).textContent = '—'; });
    ['lead-pa','5s','ps','qa','wd-tl','waterspider'].forEach(function(k) {
      document.getElementById('hours-' + k).textContent = '—';
      document.getElementById('hc-' + k).textContent = '—';
    });
  }

  // NS / SPAR standalone cards
  var nsCretsVol = crets * 0.037, nsWipVol = excess(val('ns-wip'), 4) * 100, nsTotal = nsCretsVol + nsWipVol;
  document.getElementById('ns-crets-vol').textContent = fmt(nsCretsVol);
  document.getElementById('ns-wip-vol').textContent = fmt(nsWipVol);
  document.getElementById('ns-total').textContent = fmt(nsTotal);
  document.getElementById('ns-hc').textContent = nsTotal > 0 ? Math.ceil(nsTotal / (parseFloat(document.getElementById('ns-rate').value) || 175) / 10) : 0;

  var sparCretsVol = crets * 0.002, sparWipVol = excess(val('spar-wip'), 2) * 375, sparTotal = sparCretsVol + sparWipVol;
  document.getElementById('spar-crets-vol').textContent = fmt(sparCretsVol);
  document.getElementById('spar-wip-vol').textContent = fmt(sparWipVol);
  document.getElementById('spar-total').textContent = fmt(sparTotal);
  document.getElementById('spar-hc').textContent = sparTotal > 0 ? Math.ceil(sparTotal / (parseFloat(document.getElementById('spar-rate').value) || 2) / 10) : 0;

  updateChart();
}

